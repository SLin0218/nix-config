[credential]
	helper = store
[core]
	pager	=	delta --side-by-side --width ${FZF_PREVIEW_COLUMNS-$COLUMNS}
	quotepath = false
  editor = "nvim"
[add.interactive]
    useBuiltin = false
[merge]
    conflictstyle = diff3
[diff]
    tool = kitty
    guitool = kitty.gui
[difftool]
    prompt = false
    trustExitCode = true
[difftool "kitty"]
    cmd = kitten diff $LOCAL $REMOTE
[difftool "kitty.gui"]
    cmd = kitten diff $LOCAL $REMOTE
[commit]
	gpgsign = true
[alias]
  desc = "!f() { currBr=`git symbolic-ref -q --short HEAD`;git config branch.${currBr}.description $1; }; f"
[log]
	date = format-local:%Y-%m-%d %H:%M:%S
[http]
	postBuffer = 524288000
[pull]
	rebase = false
